---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionWrapper from '../../components/SectionWrapper.astro';
import SageAccent from '../../components/SageAccent.astro';

// Wire up Keystatic posts when blog posts are available:
// import { createReader } from '@keystatic/core/reader';
// import keystaticConfig from '../../../keystatic.config';
// export async function getStaticPaths() {
//   const reader = createReader(process.cwd(), keystaticConfig);
//   const allPosts = await reader.collections.posts.all();
//   return allPosts
//     .filter(p => p.entry.published)
//     .map(post => ({ params: { slug: post.slug } }));
// }
//
// const { slug } = Astro.params;
// const reader = createReader(process.cwd(), keystaticConfig);
// const post = await reader.collections.posts.read(slug!);
// if (!post) return Astro.redirect('/blog');

export function getStaticPaths() {
  return [];
}

const { slug } = Astro.params;
---

<BaseLayout title="Post | TLC Photography">
  <SectionWrapper>
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/" class="breadcrumb-link">Home</a>
      <span class="breadcrumb-sep" aria-hidden="true"> / </span>
      <a href="/blog" class="breadcrumb-link">Journal</a>
      <span class="breadcrumb-sep" aria-hidden="true"> / </span>
      <span class="breadcrumb-current">{slug}</span>
    </nav>

    <div class="post-body">
      <div class="post-header">
        <h1 class="post-title">Post title</h1>
        <time class="post-date">Date</time>
      </div>
      <SageAccent />
      <div class="post-content">
        <p>Blog posts will appear here when added via Keystatic.</p>
      </div>
    </div>
  </SectionWrapper>
</BaseLayout>

<style>
  .breadcrumb {
    font-family: var(--font-ui);
    font-size: var(--text-small);
    margin-bottom: var(--space-xl);
  }

  .breadcrumb-link {
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .breadcrumb-link:hover {
    opacity: 0.75;
  }

  .breadcrumb-sep {
    color: var(--color-neutral);
    margin: 0 4px;
  }

  .breadcrumb-current {
    color: var(--color-neutral);
    text-transform: none;
  }

  .post-body {
    max-width: 720px;
  }

  .post-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.25;
  }

  .post-date {
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: var(--color-neutral);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-content {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 300;
    color: var(--color-text-primary);
    line-height: 1.8;
    margin-top: var(--space-xl);
  }

  .post-content :global(p) {
    margin: 0 0 var(--space-lg);
  }

  .post-content :global(h2) {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    font-weight: 400;
    margin: var(--space-2xl) 0 var(--space-md);
    color: var(--color-text-primary);
  }

  .post-content :global(h3) {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 400;
    margin: var(--space-xl) 0 var(--space-sm);
    color: var(--color-text-primary);
  }

  .post-content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .post-content :global(a:hover) {
    opacity: 0.75;
  }

  @media (max-width: 767px) {
    .post-header {
      flex-direction: column;
      gap: var(--space-xs);
    }
  }
</style>
