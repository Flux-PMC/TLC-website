---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import SageAccent from '../components/SageAccent.astro';
import CalendlyButton from '../components/CalendlyButton.astro';
import TestimonialCarousel from '../components/TestimonialCarousel';
import ImageOptimized from '../components/ImageOptimized.astro';
import heroImage from '../assets/images/hero/TLC06137.jpg';
import previewImg1 from '../assets/images/TLC05947.jpg';
import previewImg2 from '../assets/images/TLC06150.jpg';
import previewImg3 from '../assets/images/TLC06444.jpg';

const placeholderTestimonials = [
  {
    clientName: 'The Fontenot Family',
    sessionType: 'Families',
    quote:
      'She has a gift for finding the real moments — the ones you didn\'t know to pose for. We treasure every image.',
  },
  {
    clientName: 'Eloise & Marcus',
    sessionType: 'Couples',
    quote:
      'We came in a little nervous and left feeling like ourselves again. The photos show exactly who we are.',
  },
  {
    clientName: 'Class of 2026',
    sessionType: 'Seniors',
    quote:
      'I didn\'t think I was a "photo person" until I saw these. She makes it easy to just be.',
  },
];

---

<BaseLayout
  title="TLC Photography | Boutique Portrait Photography in Louisiana"
  description="TLC Photography offers boutique portrait sessions for families, couples, seniors, newborns, and more in Louisiana. Tender love lights the way."
>
  <!-- Hero -->
  <section class="hero" aria-label="Welcome to TLC Photography">
    <div class="hero-bg">
      <ImageOptimized
        src={heroImage}
        alt="Golden hour portrait session in Louisiana"
        loading="eager"
        widths={[800, 1200, 1600, 2400]}
        sizes="100vw"
      />
    </div>
    <div class="hero-content">
      <h1 class="hero-headline">Tender love lights the way.</h1>
      <p class="hero-subheading">Boutique portrait photography in Louisiana</p>
      <CalendlyButton description="" />
    </div>
  </section>

  <!-- Brand intro -->
  <SectionWrapper>
    <SageAccent />
    <div class="intro-block">
      <p class="intro-text">
        TLC Photography is a boutique portrait studio serving central and northeast Louisiana. Every session is built around the moment after the pose — when the guard drops and something real surfaces. These are images made to last a lifetime.
      </p>
    </div>
  </SectionWrapper>

  <!-- Featured portfolio -->
  <SectionWrapper bg="var(--color-surface)">
    <h2 class="section-heading">Recent Work</h2>
    <SageAccent />
    <div class="portfolio-preview" style="margin-top: var(--space-xl);">
      <ImageOptimized
        src={previewImg1}
        alt="Portrait in soft Louisiana light"
        loading="lazy"
        aspectRatio="4/5"
        widths={[400, 600, 800]}
        sizes="(max-width: 640px) 50vw, 33vw"
      />
      <ImageOptimized
        src={previewImg2}
        alt="Outdoor portrait at golden hour"
        loading="lazy"
        aspectRatio="4/5"
        widths={[400, 600, 800]}
        sizes="(max-width: 640px) 50vw, 33vw"
      />
      <ImageOptimized
        src={previewImg3}
        alt="Candid moment during a portrait session"
        loading="lazy"
        aspectRatio="4/5"
        widths={[400, 600, 800]}
        sizes="(max-width: 640px) 50vw, 33vw"
      />
    </div>
    <div style="margin-top: var(--space-xl);">
      <a href="/portfolio" class="text-link">View the full portfolio →</a>
    </div>
  </SectionWrapper>

  <!-- Testimonials -->
  <SectionWrapper>
    <SageAccent />
    <h2 class="section-heading" style="margin-bottom: var(--space-xl);">From Clients</h2>
    <TestimonialCarousel
      client:visible
      testimonials={placeholderTestimonials}
    />
  </SectionWrapper>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  /* Force the image wrapper to fill the hero background absolutely */
  .hero-bg :global(.image-wrapper) {
    position: absolute !important;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    aspect-ratio: unset !important;
  }

  /* Force picture and img to fill */
  .hero-bg :global(picture),
  .hero-bg :global(img) {
    position: absolute !important;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    border-radius: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 600px;
    padding: var(--space-5xl) var(--margin-mobile);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .hero-headline {
    font-family: var(--font-heading);
    font-size: var(--text-hero);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.15;
  }

  .hero-subheading {
    font-family: var(--font-subheading);
    font-size: var(--text-subheading);
    font-style: italic;
    font-weight: 300;
    color: var(--color-neutral);
    margin: 0;
  }

  /* Intro */
  .intro-block {
    max-width: 640px;
    margin-top: var(--space-xl);
  }

  .intro-text {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 300;
    color: var(--color-text-primary);
    line-height: 1.8;
    margin: 0;
  }

  /* Section headings */
  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-md);
  }

  .section-subheading {
    font-family: var(--font-subheading);
    font-size: var(--text-subheading);
    font-style: italic;
    font-weight: 300;
    color: var(--color-neutral);
    margin: var(--space-md) 0 0;
    max-width: 520px;
  }

  /* Portfolio preview placeholders */
  .portfolio-preview {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  .text-link {
    font-family: var(--font-ui);
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .text-link:hover {
    opacity: 0.75;
  }

  @media (min-width: 640px) {
    .portfolio-preview {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 768px) {
    .hero-content {
      padding: var(--space-5xl) var(--margin-tablet);
    }
  }

  @media (min-width: 1200px) {
    .hero-content {
      padding: var(--space-5xl) var(--margin-desktop);
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 60vh;
    }

    .hero-headline {
      font-size: 36px;
    }
  }
</style>
