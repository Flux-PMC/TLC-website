---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import SageAccent from '../components/SageAccent.astro';
import PortfolioGrid from '../components/PortfolioGrid';

const portfolioImages = [
  { title: 'Portrait session', src: '/images/TLC00200.jpg', alt: 'Portrait in soft natural light', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC00221.jpg', alt: 'Candid outdoor portrait', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC01388.jpg', alt: 'Portrait in warm Louisiana light', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC01411.jpg', alt: 'Relaxed portrait session', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC02266.jpg', alt: 'Portrait in dappled shade', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC02268.jpg', alt: 'Quiet moment during a portrait session', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC02278.jpg', alt: 'Natural light portrait', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC02281.jpg', alt: 'Outdoor portrait at golden hour', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC05793.jpg', alt: 'Portrait with soft background', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC05947.jpg', alt: 'Sunlit outdoor portrait', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC06150.jpg', alt: 'Portrait in open shade', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC06390.jpg', alt: 'Soft portrait in evening light', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC06418.jpg', alt: 'Candid moment between poses', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC06444.jpg', alt: 'Portrait framed by foliage', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC06456-2-2.jpg', alt: 'Natural outdoor portrait', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC09152.jpg', alt: 'Portrait in warm afternoon light', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC09158.jpg', alt: 'Relaxed portrait in natural setting', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC09786.jpg', alt: 'Outdoor portrait with soft background', category: 'portraits' },
  { title: 'Portrait session', src: '/images/TLC09808.jpg', alt: 'Portrait in Louisiana light', category: 'portraits' },
];
---

<BaseLayout
  title="Portfolio | TLC Photography"
  description="Browse TLC Photography's curated portrait portfolio. Families, couples, seniors, newborns, maternity, and engagement sessions in Louisiana."
>
  <SectionWrapper>
    <h1 class="page-title">Portfolio</h1>
    <SageAccent />

    <div style="margin-top: var(--space-xl);">
      {portfolioImages.length > 0 ? (
        <PortfolioGrid client:visible images={portfolioImages} />
      ) : (
        <p class="empty-message">Portfolio images coming soon.</p>
      )}
    </div>
  </SectionWrapper>
</BaseLayout>

<style>
  .page-title {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: 400;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-md);
    line-height: 1.2;
  }

  .empty-message {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-neutral);
    margin: var(--space-xl) 0 0;
  }
</style>
